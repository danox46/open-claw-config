# Ignore everything by default
*

# Keep the gitignore itself
!.gitignore

# Keep main config
!openclaw.json

# Keep shared custom assets
!skills/
!skills/**

!scripts/
!scripts/**

!docs/
!docs/**

!templates/
!templates/**

# Keep agent workspaces
!workspace-*/

# Keep agent config files
!workspace-*/AGENTS.md
!workspace-*/SOUL.md
!workspace-*/USER.md
!workspace-*/IDENTITY.md
!workspace-*/TOOLS.md
!workspace-*/HEARTBEAT.md
!workspace-*/README.md

# Keep memory content
!workspace-*/memory/
!workspace-*/memory/**

# Ignore secrets/runtime junk
.env
.env.*
*.log
logs/
tmp/
cache/
sessions/
auth/
profiles/
sandboxes/